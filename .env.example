# --- Core ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/carousel_agent"
REDIS_URL="redis://localhost:6379"

# --- Auth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-a-real-secret"
NEXTAUTH_URL="http://localhost:3000"
# Used to encrypt Instagram access tokens at rest (falls back to NEXTAUTH_SECRET)
APP_ENCRYPTION_KEY=""

# --- AI provider: mock | anthropic | openai ---
# "mock" works fully offline with deterministic output (good for dev/demo).
LLM_PROVIDER="mock"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Instagram adapter: mock | graph ---
# "mock" simulates discovery + publishing. "graph" uses the official Instagram Graph API
# and requires a Business/Creator account, a Meta app, and approved permissions.
IG_ADAPTER="mock"
IG_GRAPH_API_VERSION="v21.0"

# --- Storage: local | s3 ---
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR=""
# Public origin of this app (required for real Graph API publishing, which needs
# publicly reachable image URLs), e.g. https://yourapp.example.com
PUBLIC_ASSET_BASE_URL=""

# --- S3 (only if STORAGE_DRIVER=s3; driver stub must be implemented first) ---
S3_BUCKET=""
S3_REGION=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
