generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  agents       Agent[]
}

enum AgentMode {
  APPROVAL
  AUTO
}

enum AgentStatus {
  ACTIVE
  PAUSED
}

model Agent {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  niche        String
  tone         String      @default("friendly, expert, practical")
  audience     String      @default("")
  goals        String      @default("")
  scheduleCron String      @default("0 9 * * 1,3,5")
  mode         AgentMode   @default(APPROVAL)
  status       AgentStatus @default(ACTIVE)
  brand        Json        @default("{}")
  createdAt    DateTime    @default(now())

  igConnection InstagramConnection?
  sources      InspirationSource[]
  posts        CollectedPost[]
  insights     Insight[]
  drafts       CarouselDraft[]
  runs         RunLog[]
}

model InstagramConnection {
  id             String    @id @default(cuid())
  agentId        String    @unique
  agent          Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  igUserId       String
  username       String    @default("")
  accessTokenEnc String
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())
}

enum SourceType {
  IG_HANDLE
  HASHTAG
  RSS
  URL
  MANUAL
}

model InspirationSource {
  id        String          @id @default(cuid())
  agentId   String
  agent     Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type      SourceType
  value     String
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  posts     CollectedPost[]
}

model CollectedPost {
  id              String             @id @default(cuid())
  agentId         String
  agent           Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sourceId        String?
  source          InspirationSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceType      SourceType
  sourceUrl       String?
  author          String?
  caption         String             @default("")
  topic           String             @default("")
  format          String             @default("unknown")
  likeCount       Int?
  commentCount    Int?
  postedAt        DateTime?
  collectedAt     DateTime           @default(now())
  engagementScore Float              @default(0)
  rankScore       Float              @default(0)
  insight         Insight?

  @@unique([agentId, sourceUrl])
}

model Insight {
  id               String          @id @default(cuid())
  agentId          String
  agent            Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  postId           String          @unique
  post             CollectedPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  hookStyle        String
  emotionalAngle   String
  painPoint        String
  structure        String
  cta              String
  topicCluster     String
  visualPattern    String
  strategicInsight String
  score            Float           @default(0)
  createdAt        DateTime        @default(now())
  drafts           CarouselDraft[]
}

enum DraftStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  REJECTED
}

model CarouselDraft {
  id           String       @id @default(cuid())
  agentId      String
  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  insightId    String?
  insight      Insight?     @relation(fields: [insightId], references: [id], onDelete: SetNull)
  title        String
  slides       Json
  caption      String
  hashtags     String[]
  altTexts     String[]
  rationale    String       @default("")
  status       DraftStatus  @default(DRAFT)
  scheduledFor DateTime?
  publishedAt  DateTime?
  igMediaId    String?
  error        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  assets       SlideAsset[]
}

model SlideAsset {
  id         String        @id @default(cuid())
  draftId    String
  draft      CarouselDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  idx        Int
  storageKey String
  width      Int           @default(1080)
  height     Int           @default(1350)
  createdAt  DateTime      @default(now())

  @@unique([draftId, idx])
}

enum RunStatus {
  RUNNING
  SUCCESS
  FAILED
}

model RunLog {
  id         String    @id @default(cuid())
  agentId    String
  agent      Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  jobType    String
  status     RunStatus @default(RUNNING)
  message    String    @default("")
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}
